<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.pocketlinux.de">

    <!-- Required to send RUN_COMMAND intents to Termux. The user must grant this
         permission once via Settings; we open the right page for them on first
         launch. -->
    <uses-permission android:name="com.termux.permission.RUN_COMMAND" />

    <!-- Internet is for the localhost VNC connection (yes, that requires this
         permission on Android — even loopback). -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- We use a foreground service while the desktop session is active so
         Android doesn't kill the VNC connection when the user backgrounds the
         app briefly. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- For the bell-on-VNC-bell behavior. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Visibility into other packages — needed on Android 11+ to even check
         if Termux is installed. -->
    <queries>
        <package android:name="com.termux" />
    </queries>

    <application
        android:label="@string/app_name"
        android:icon="@android:drawable/sym_def_app_icon"
        android:theme="@style/Theme.PocketLinux"
        android:allowBackup="false"
        android:hardwareAccelerated="true">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.ViewerActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|keyboardHidden|keyboard"
            android:theme="@style/Theme.PocketLinux.Fullscreen"
            android:windowSoftInputMode="adjustResize" />
    </application>
</manifest>
